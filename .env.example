# =============================================
# SOLANA DEGEN BOT - Environment Configuration
# =============================================

# --- WALLET ---
# Private key dalam format base58 (JANGAN PERNAH SHARE!)
WALLET_PRIVATE_KEY=your_base58_private_key_here

# --- RPC ENDPOINTS ---
# ✅ FREE OPTION (cukup untuk testing — strategi ini BUKAN HFT):
# Token yang ditrade sudah berumur >1 jam, jadi latency bukan masalah.
# Public RPC bisa kena rate-limit pada volume tinggi tapi aman untuk testing.
#
# Jika TIDAK di-set, bot otomatis pakai: https://api.mainnet-beta.solana.com
# Fallback list ada di src/config/index.ts (3 endpoint gratis dirotasi otomatis)
#
# ⚡ UPGRADE ke premium (opsional, untuk production):
#   Helius   → https://helius.dev              (free tier 10k req/day)
#   QuickNode→ https://quicknode.com           (free tier tersedia)
#   Triton   → https://triton.one
#
SOLANA_RPC_URL=
# SOLANA_WS_URL=   # Opsional, auto-derived dari RPC URL

# --- JITO (MEV Protection) ---
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf
# Jito tip amount in SOL (minimal 0.0001 SOL)
JITO_TIP_AMOUNT=0.0001

# --- TELEGRAM ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- DATA SOURCES ---
# GMGN.ai (primary) → DexScreener (free fallback, no key needed)
# Bot otomatis switch ke DexScreener jika GMGN gagal 3x berturut-turut
# dan reset otomatis setelah 5 menit.
GMGN_BASE_URL=https://gmgn.ai
GMGN_API_KEY=   # Opsional: kosongkan untuk pakai public endpoint
# Session cookie dari browser untuk bypass GMGN 403 (bukan API key)
# Cara dapat: buka gmgn.ai → F12 → Application → Cookies → copy value "session"
# Lihat scripts/get-gmgn-session.js untuk panduan lengkap
GMGN_SESSION_COOKIE=

# --- TRADING PARAMETERS (Obicle Strategy) ---
# Max trade size per transaksi dalam SOL
MAX_TRADE_SOL=0.1
# Minimum market cap dalam USD
MIN_MCAP_USD=150000
# Maximum market cap dalam USD (degen = micro-cap, default $5M)
MAX_MCAP_USD=5000000
# Obicle fee ratio: minimum SOL fee per $1K market cap (default 0.1 = 10%)
# Contoh: mcap $237K => 237 * 0.1 = 23.7 SOL fee minimal
# Turunkan kalau terlalu sedikit token yang lolos, naikkan kalau ingin lebih strict
MIN_FEE_SOL_PER_1K_MCAP=0.1
# Minimum age token dalam detik (1 jam = 3600)
MIN_TOKEN_AGE_SECONDS=3600
# Max price impact (%) sebelum cancel transaksi
MAX_PRICE_IMPACT_PCT=2.0
# Slippage dinamis min-max (%)
SLIPPAGE_MIN_PCT=0.5
SLIPPAGE_MAX_PCT=3.0

# --- DRY RUN MODE ---
# true  = scan + signal + simulasi berjalan, tapi ZERO transaksi on-chain.
#         Wallet kosong pun aman. Paper trade dicatat di memory.
#         Gunakan ini untuk validasi scanner sebelum deposit SOL.
# false = live trading (default)
DRY_RUN=true


# 180s (3 menit) = aman GMGN free tier. 1 cycle ~15 detik actual.
# Turunkan ke 60 hanya kalau pakai premium GMGN key.
SCAN_INTERVAL_SECONDS=180

# Monitor open positions tiap berapa detik (default 120 = 2 menit)
# Naikkan kalau sering overlap dengan scan.
MONITOR_INTERVAL_SECONDS=120

# HTTP/HTTPS Proxy untuk bypass GMGN IP block (opsional)
# Format: http://user:pass@host:port atau socks5://host:port
# PROXY_URL=http://proxy:8080

# --- RISK MANAGEMENT ---
# Max open positions bersamaan
MAX_OPEN_POSITIONS=3
# Stop loss percentage (%)
STOP_LOSS_PCT=15
# true = bot auto-sell only when STOP_LOSS_PCT is hit.
# Buy approval and profit-taking sells stay manual.
AUTO_STOP_LOSS_ENABLED=true
# Take profit percentage (%) - untuk notifikasi manual
TAKE_PROFIT_PCT=50

# --- LOGGING ---
LOG_LEVEL=info
LOG_FILE=logs/bot.log

# --- FINE TUNING (opsional, ada default semua) ---
# Naikkan threshold kalau sinyal terlalu jarang
# Turunkan kalau terlalu banyak false signal
RSI_BOTTOMING_THRESHOLD=20     # default 20, range 15-35
EMA_TOUCH_TOLERANCE_PCT=2.0    # default 2.0%, range 1.0-5.0
APPROVAL_TTL_MINUTES=10        # default 10 menit, naik kalau sering tidur

# --- STRATEGY v2: TREND & VOLUME FILTERS ---
# Hanya buy jika harga di atas EMA ini (default 50)
TREND_EMA_PERIOD=50
# EMA alignment: FAST_EMA > SLOW_EMA (default 25 > 50)
FAST_EMA_PERIOD=25
SLOW_EMA_PERIOD=50
# Max 1h dump yang diperbolehkan (negative = allowed drop, default -15)
MAX_1H_DROP_PCT=-15
# Minimum volume surge ratio (1.0 = volume >= average)
MIN_VOLUME_SURGE_RATIO=1.2
# false = block buy signals from DexScreener synthetic OHLCV fallback.
# Set true only if GMGN OHLCV is unavailable and you accept noisier signals.
ALLOW_SYNTHETIC_OHLCV_SIGNALS=false

# --- STRATEGY v2: RISK MANAGEMENT ---
# Tight stop loss (default 8% untuk degen coins)
STOP_LOSS_PCT=8
# Auto sell only on hard stop-loss. Profit exits remain manual.
AUTO_STOP_LOSS_ENABLED=true
# Trailing stop: aktif setelah profit +15%, trigger kalau turun -10% dari peak
TRAILING_STOP_ENABLED=true
TRAILING_STOP_ACTIVATION_PCT=15
TRAILING_STOP_DISTANCE_PCT=10
# Partial take profit: jual 50% posisi di +30%
PARTIAL_TP_ENABLED=true
PARTIAL_TP_PCT=30
PARTIAL_TP_SIZE_PCT=50
# Time exit: keluar kalau posisi stagnan >4 jam & tidak profit
TIME_EXIT_MINUTES=240
TIME_EXIT_PNL_THRESHOLD=-2
